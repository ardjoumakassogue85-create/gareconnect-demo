# Variables d'environnement necessaires pour le backend.
# Copie ce fichier vers backend/.env puis remplace les valeurs entre <>.
# Le fichier backend/.env est ignore par Git pour proteger le mot de passe.

# --- Supabase ---
# Dans Supabase : Project Settings > Database > Connection string.
# Option recommandee : Session pooler, port 5432.
# Garde le prefixe JDBC ci-dessous pour Spring Boot.
SUPABASE_DB_URL=jdbc:postgresql://<pooler-host>:5432/postgres?sslmode=require

# Selon le format affiche par Supabase, l'utilisateur ressemble souvent a :
# postgres.<project-ref>
SUPABASE_DB_USER=<utilisateur_supabase>
SUPABASE_DB_PASSWORD=<mot_de_passe_database>

# --- JWT ---
# Genere une chaine aleatoire longue, au moins 32 caracteres.
JWT_SECRET=<chaine_secrete_longue>
JWT_EXPIRATION_MS=86400000

# --- CORS ---
# En local : http://localhost:4200
# En production : URL Vercel du frontend
ALLOWED_ORIGINS=http://localhost:4200
